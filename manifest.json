{
  "manifest_version": 3,
  "name": "Context Compressor",
  "description": "One-click conversation compression for Claude.ai — compress long chats into dense context resumes you can paste into a new conversation.",
  "version": "1.0.0",

  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://claude.ai/*"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
